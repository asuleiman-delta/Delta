  <!DOCTYPE html>
  <html>
    <head>
      <style>
        body {
          padding: 0;
          margin: 0;
          width: 100%;
          height: 100vh;
          display: block;
          align-items: ${i};
          justify-content:center;
          overflow: auto;
        }
        .hbspt-form {
          width: ${n}%;
          height: 100%;
          display: grid;
        }
        .hbspt-form .hs-form-iframe {
          padding: 2em 0;
          place-self: center;
        }
        
        /* resets for marketo forms */
        #arcade-embed-code-sandbox form {
          box-sizing: border-box;
          font-family: 'Inter', Arial, Helvetica, sans-serif !important;
        }

        #arcade-embed-code-sandbox .mktoForm {
          display: block !important;
          transform: none !important;
          position: static !important;
          top: 0 !important;
          margin: 0 !important;
          padding: 20px !important;
        }

        #arcade-embed-code-sandbox .mktoFormRow,
        #arcade-embed-code-sandbox .mktoFormCol,
        #arcade-embed-code-sandbox .mktoFieldWrap {
          box-sizing: border-box;
          max-width: 100%;
          font-family: 'Inter', Arial, Helvetica, sans-serif !important;
        }
        #arcade-embed-code-sandbox .mktoForm .mktoFormRow label.mktoLabel.mktoHasWidth, #arcade-embed-code-sandbox .mktoForm .mktoFormRow label.mktoLabel {
          font-family: 'Inter', Arial, Helvetica, sans-serif !important;
        }

        /* remove random gutter */
        #arcade-embed-code-sandbox .mktoForm .mktoGutter {
          height: auto !important;
        }

        /* context box sizing and some nice defaults for form fields */
        #arcade-embed-code-sandbox .mktoForm input[type=text], #arcade-embed-code-sandbox .mktoForm input[type=url], #arcade-embed-code-sandbox .mktoForm input[type=email], #arcade-embed-code-sandbox .mktoForm input[type=tel], #arcade-embed-code-sandbox .mktoForm input[type=number], #arcade-embed-code-sandbox .mktoForm input[type=date], #arcade-embed-code-sandbox .mktoForm textarea.mktoField, #arcade-embed-code-sandbox .mktoForm select.mktoField {
          font-family: 'Inter', Arial, Helvetica, sans-serif !important;
          border:none !important;
          padding: 10px 14px !important;
          border-radius: 8px !important;
          box-sizing: border-box !important;
          height: auto !important;
          box-shadow: 0px 0px 0px 1px rgba(17, 24, 39, 0.12), 0 0 12px rgba(17, 24, 39, 0.06) !important;
        }
      </style>
      <script>
        const Arcade = {
          GoToNextStep() {
            if (${t}) {
              window.parent.postMessage({type: 'arcade-command', eventName: 'navToNextStep'}, '*')
            }
          }
        }
        window.addEventListener('message', function(event) {
          if (event.isTrusted && (origin.endsWith('arcade.software') || origin.endsWith('localhost:3000'))) { 
            // HubSpot form submission
            if(event.data.type === 'hsFormCallback' && event.data.eventName === 'onFormSubmitted') {
              Arcade.GoToNextStep();
            }
          }

          // Typeform submission
          if (event.isTrusted && event.origin.endsWith('form.typeform.com')) {
            if (event.data.type === 'form-submit') {
             Arcade.GoToNextStep();
            }
          }
        })
      </script>
    </head>
    <body><div id="arcade-embed-code-sandbox">${r}</div></body>
